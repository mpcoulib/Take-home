# --- Local dev (optional) ---
# ANTHROPIC_API_KEY=sk-ant-...
# PORT=8000
# DATASET=cms:xubh-q36u

# --- Supabase / production data store ---
# Project URL (safe for frontend; no secret)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon key (read-only with RLS; optional for future client-side use)
# SUPABASE_ANON_KEY=eyJ...

# Service role key (server-only — never expose in frontend or commit)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct Postgres connection (required for backend reads/writes)
# Supabase → Project Settings → Database → Connection string (URI)
# Use the "Transaction" pooler URL for serverless (port 6543).
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
