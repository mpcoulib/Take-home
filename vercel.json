{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{data/**,backend/tests/**,backend/.pytest_cache/**,.pytest_cache/**,scripts/**,supabase/**,Figma design files/**,notebooks/**,*.md,!README.md,backend/verify_*.py}"
    }
  }
}
